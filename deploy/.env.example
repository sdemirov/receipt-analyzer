# Copy to the repo root as `.env` on the server (it is gitignored).
# docker compose and deploy/refresh.sh both read it.

# Local disk path where rclone syncs the receipts; also the Compose mount source.
# Must end up containing the per-store subfolders Kaufland/ and Lidl/.
RECEIPTS_HOST_DIR=/srv/digitalreceipts

# rclone remote that points at the DigitalReceipts folder (so `rclone ls $REMOTE`
# lists Kaufland/ and Lidl/). Used by deploy/refresh.sh.
RCLONE_REMOTE=gdrive:
